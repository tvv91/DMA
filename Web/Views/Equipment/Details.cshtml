@model EquipmentViewModel 

<div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="toasterror" class="toast toast-error" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="toast-header toast-header-error">
      <strong class="me-auto">Error</strong>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body">Some error during deletion</div>
  </div>
  <div id="toastinfo_updated" class="toast toast-info" role="alert" aria-live="polite" aria-atomic="true">
    <div class="toast-header">
      <strong class="me-auto">Information</strong>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body">Equipment updated</div>
  </div>
  <div id="toastinfo_created" class="toast toast-success" role="alert" aria-live="polite" aria-atomic="true">
    <div class="toast-header">
      <strong class="me-auto">Information</strong>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body">Equipment created</div>
  </div>
  <div id="toastinfo_deleted" class="toast toast-warning" role="alert" aria-live="polite" aria-atomic="true">
    <div class="toast-header">
      <strong class="me-auto">Information</strong>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body">Equipment deleted</div>
  </div>
</div>
<div class="modal fade" id="removeDialogModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5">Are you sure?</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Data cannot be restored
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-danger" onclick="onRemove(@Model.Id)">Delete</button>
      </div>
    </div>
  </div>
</div>
<a id="back_button" class="btn btn-back mt-3" asp-action="index" asp-controller="equipment"><i class="fa fa-arrow-left"></i> Back</a>
@{
    var eqCategory = Model?.EquipmentType.ToString().ToLowerInvariant() ?? "";
    var eqId = Model?.Id ?? 0;
    var albumsPageSize = Model?.DigitizedAlbumsPage?.PageSize ?? 18;
    var baseAlbumsUrl = $"/equipment/{eqCategory}/{eqId}?tab=albums&pageSize={albumsPageSize}";
}
<div class="equipment-detail-with-tabs">
<ul class="nav nav-tabs mt-3" id="equipmentDetailTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <a class="nav-link @(Model?.ActiveTab != "albums" ? "active" : "")" href="/equipment/@eqCategory/@eqId" role="tab">General</a>
    </li>
    <li class="nav-item" role="presentation">
        <a class="nav-link @(Model?.ActiveTab == "albums" ? "active" : "")" href="@(baseAlbumsUrl)&page=1" role="tab">Albums</a>
    </li>
</ul>
<div class="tab-content mt-2" id="equipmentDetailTabContent">
    <div class="tab-pane fade @(Model?.ActiveTab != "albums" ? "show active" : "")" id="info-pane" role="tabpanel">
        <div class="equipment-detail-containter">
            <div id="coverdiv" class="box1">
                <div id="coverspinner" class="spinner-grow text-light justifiy-element-size"></div>
                <i id="nocovericon" class="fa-regular fa-image fa-6x d-none"></i>
                <img id="cover" class="equipment-cover justifiy-element-size d-none" />
            </div>
            <div class="equipment-detail-box">
                <div>
                    <a data-bs-toggle="modal" data-bs-target="#removeDialogModal">
                        <i class="fa-solid fa-trash fa-lg fa-pull-right"></i>
                    </a>
                    <a href="/equipment/@Model?.EquipmentType.ToString().ToLower()/@Model?.Id/edit">
                        <i class="fa-solid fa-pen-to-square fa-lg fa-pull-right"></i>
                    </a>

                    @if (Model?.Manufacturer != null) {
                        <h1><b>@Model?.Manufacturer</b> @Model?.ModelName</h1>
                        <b>Manufacturer: </b> @Model?.Manufacturer <br />
                        <b>Model: </b> @Model?.ModelName
                    } else {
                        <h1>@Model?.ModelName</h1>
                        <b>Model: </b> @Model?.ModelName
                    }
                </div>
                @if (Model?.Description != null) {
                    <div class="equipment-detail-description">
                        <textarea class="equipment-description" readonly>@Model?.Description</textarea>
                    </div>
                } else {
                    <p class="text-muted mb-0">No description.</p>
                }
            </div>
        </div>
    </div>
    <div class="tab-pane fade @(Model?.ActiveTab == "albums" ? "show active" : "")" id="albums-pane" role="tabpanel"
         data-eq-category="@eqCategory"
         data-eq-id="@eqId"
         data-albums-partial-url="@Url.Action("EquipmentAlbumsData", "Equipment", new { category = Model!.EquipmentType, id = Model.Id })">
        <div id="equipment-albums-inner">
        @if (Model?.ActiveTab == "albums" && Model.DigitizedAlbumsPage != null)
        {
            @await Html.PartialAsync("_EquipmentDigitizedAlbumsInner", Model.DigitizedAlbumsPage)
        }
        </div>
    </div>
</div>
</div>
<script>
      function equipmentAlbumsDataFetchUrl(detailsUrl) {
        const pane = document.getElementById('albums-pane');
        if (!pane || !pane.dataset.albumsPartialUrl) return '';
        const u = new URL(detailsUrl, window.location.origin);
        const page = u.searchParams.get('page') || '1';
        const pageSize = u.searchParams.get('pageSize') || '18';
        const sep = pane.dataset.albumsPartialUrl.includes('?') ? '&' : '?';
        return `${pane.dataset.albumsPartialUrl}${sep}page=${encodeURIComponent(page)}&pageSize=${encodeURIComponent(pageSize)}`;
      }

      async function loadEquipmentAlbumsPartial(detailsPageUrl, pushState) {
        const inner = document.getElementById('equipment-albums-inner');
        if (!inner) return;
        const fetchUrl = equipmentAlbumsDataFetchUrl(detailsPageUrl);
        if (!fetchUrl) return;
        const res = await fetch(fetchUrl, {
          credentials: 'same-origin',
          headers: { 'Accept': 'text/html', 'X-Requested-With': 'XMLHttpRequest' }
        });
        if (!res.ok) return;
        inner.innerHTML = await res.text();
        if (pushState) {
          const u = new URL(detailsPageUrl, window.location.origin);
          history.pushState({}, '', u.pathname + u.search);
        }
        const albumIds = [...inner.querySelectorAll('[data-album-id]')].map((el) => parseInt(el.getAttribute('data-album-id'), 10)).filter((id) => !Number.isNaN(id));
        if (albumIds.length > 0) {
          try {
            await connection.invoke("GetAlbumCovers", connection.connectionId, albumIds);
          } catch (err) { console.error("GetAlbumCovers:", err); }
        }
      }

      connection.on("ReceivedAlbumCover", (albumId, cover) => {
        const img = $("#album-img-" + albumId);
        const spinner = $("#spinner-" + albumId);
        if (img.length === 0 || spinner.length === 0) return;
        img.off("load error")
          .on("load", () => { spinner.addClass("hidden"); img.removeClass("d-none"); })
          .on("error", () => { img.attr("src", "/img/nocover.png"); spinner.addClass("hidden"); img.removeClass("d-none"); });
        img.attr("src", cover);
        if (img[0].complete && img[0].naturalHeight !== 0) { spinner.addClass("hidden"); img.removeClass("d-none"); }
        else if (img[0].complete && img[0].naturalHeight === 0) img.trigger("error");
      });

      $(document).on('click', '#albums-pane .album-pagination a.page-link', function (e) {
        if (e.ctrlKey || e.metaKey || e.shiftKey || e.button !== 0) return;
        const href = this.getAttribute('href');
        if (!href || !href.toLowerCase().includes('tab=albums')) return;
        e.preventDefault();
        loadEquipmentAlbumsPartial(href, true);
      });

      window.addEventListener('popstate', () => {
        const u = new URL(window.location.href);
        if (u.searchParams.get('tab') === 'albums') {
          loadEquipmentAlbumsPartial(window.location.href, false);
        } else {
          window.location.reload();
        }
      });

      $(document).ready(async () => {
        await start();
        await getEquipmentImage(@(Model?.Id ?? 0));

        showToast("equipment_updated", "toastinfo_updated");
        showToast("equipment_created", "toastinfo_created");
        showToast("equipment_deleted", "toastinfo_deleted");

        @if (Model?.DigitizedAlbumsPage?.HasResults == true) {
          <text>
          (async function loadEquipmentAlbumCoversInitial() {
            try {
              await connection.invoke("GetAlbumCovers", connection.connectionId, @Json.Serialize(Model.DigitizedAlbumsPage.Albums.Select(a => a.Id).ToList()));
            } catch (err) { console.error("GetAlbumCovers:", err); }
          })();
          </text>
        }
      });

      function showToast(key, toastId) {
        if (sessionStorage.getItem(key) === "1") {
          $(`#${toastId}`).toast('show');
          sessionStorage.removeItem(key);
        }
      }

      async function getEquipmentImage(id) {
        try {
          await equipmentConnection.invoke("GetEquipmentImage", equipmentConnection.connectionId, id, "@(Model?.EquipmentType.ToString() ?? "Adc")");
        } catch (err) {
          console.error("Error sending request to GetEquipmentImage:", err);
        }
      }


    equipmentConnection.on("ReceivedEquipmentImageDetailed", (result) => {
        updateCover(result);
    });


    function updateCover(src) {
      $('#coverspinner').addClass("d-none");
      if (!src || src.includes("nocover")) {
        $('#cover').attr("src", "").addClass("d-none");
        $('#nocovericon').removeClass("d-none");
        $('#coverdiv').css("border", "2px dashed #ccc");
      } else {
        $('#cover').attr("src", src).fadeIn(500).removeClass("d-none");
        $('#nocovericon').addClass("d-none");
        $('#coverdiv').css("border", "none");
      }
    }

    async function onRemove(id) {
    try {
      const response = await fetch(`delete?id=${id}`, { method: "DELETE" });

      if (response.ok) {
        sessionStorage.setItem("equipment_deleted", "1");
        window.location.href = "/equipment";
      } else {
        $('#toasterror').toast('show');
      }
    } catch (err) {
      console.error("Deletion failed:", err);
      $('#toasterror').toast('show');
    }
  }
</script>
